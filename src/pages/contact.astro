---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Any Debt Collections — Free Consultation"
  description="Get in touch with Any Debt Collections. Free consultation, no obligation, no upfront fees. Call, email, or WhatsApp Angelique today. Serving all of South Africa from Howick, KZN."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="contact-hero" id="hero">
    <div class="container contact-hero-inner">
      <span class="eyebrow">Get in Touch</span>
      <h1 class="contact-hero-heading">Let's Get Your Money Back</h1>
      <p class="contact-hero-sub">Free consultation. No obligation. No upfront fees.</p>
    </div>
    <div class="hero-watermark" aria-hidden="true">
      <svg viewBox="0 0 100 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M50 5L10 20v35c0 25 18 47 40 55 22-8 40-30 40-55V20L50 5z" stroke="currentColor" stroke-width="3" fill="none"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CONTACT METHOD CARDS                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad contact-methods-section">
    <div class="container">
      <div class="contact-methods-grid">

        <!-- Phone -->
        <div class="contact-card reveal">
          <div class="contact-card-icon navy">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.47 2 2 0 0 1 3.59 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.68a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
            </svg>
          </div>
          <h2 class="contact-card-title">Call Us</h2>
          <p class="contact-card-desc">Speak directly with Angelique. Available during business hours.</p>
          <div class="contact-card-links">
            <a href="tel:+27621165638" class="contact-phone-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.47 2 2 0 0 1 3.59 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.68a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
              </svg>
              062 116 5638
            </a>
            <a href="tel:+27814158260" class="contact-phone-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.47 2 2 0 0 1 3.59 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.68a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
              </svg>
              081 415 8260
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="contact-card reveal delay-1">
          <div class="contact-card-icon crimson">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h2 class="contact-card-title">Email Us</h2>
          <p class="contact-card-desc">Send us a message and we'll respond within 24 hours.</p>
          <div class="contact-card-links">
            <a href="mailto:anycollections@outlook.com" class="contact-email-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              anycollections@outlook.com
            </a>
          </div>
        </div>

        <!-- WhatsApp -->
        <div class="contact-card reveal delay-2">
          <div class="contact-card-icon whatsapp">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h2 class="contact-card-title">WhatsApp</h2>
          <p class="contact-card-desc">Prefer to chat? Message us directly on WhatsApp — quick and easy.</p>
          <div class="contact-card-links">
            <a
              href="https://wa.me/27621165638?text=Hi%2C+I%27d+like+to+enquire"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-whatsapp btn-full"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat on WhatsApp
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CONTACT FORM                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad contact-form-section" id="contact-form">
    <div class="container contact-form-wrap">
      <div class="section-center-header reveal" style="margin-bottom:2.5rem;">
        <span class="eyebrow">Send Us a Message</span>
        <h2 class="section-heading" style="font-size:2rem;">Tell Us About Your Situation</h2>
        <p style="color:var(--color-warm-600); margin-top:0.75rem;">We'll get back to you within 24 hours with a clear plan of action.</p>
      </div>

      <form
        class="contact-form reveal"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        id="contactForm"
        novalidate
      >
        <div class="form-row">
          <div class="form-group">
            <label for="name">Full Name <span aria-hidden="true">*</span></label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name" />
          </div>
          <div class="form-group">
            <label for="business">Business Name <span aria-hidden="true">*</span></label>
            <input type="text" id="business" name="business" placeholder="Your Business Name" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="email">Email Address <span aria-hidden="true">*</span></label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required autocomplete="email" />
          </div>
          <div class="form-group">
            <label for="phone">Phone Number <span aria-hidden="true">*</span></label>
            <input type="tel" id="phone" name="phone" placeholder="0XX XXX XXXX" required autocomplete="tel" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="industry">Industry</label>
            <select id="industry" name="industry">
              <option value="">Select your industry…</option>
              <option value="school">School / Education</option>
              <option value="medical">Medical / Dental</option>
              <option value="enterprise">Enterprise / Business</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="debt-value">Estimated Outstanding Debt</label>
            <select id="debt-value" name="debt_value">
              <option value="">Select a range…</option>
              <option value="under-10k">Under R10,000</option>
              <option value="10k-50k">R10,000 – R50,000</option>
              <option value="50k-200k">R50,000 – R200,000</option>
              <option value="200k-plus">R200,000+</option>
              <option value="prefer-not">Prefer not to say</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" placeholder="Tell us about your outstanding debts and how we can help…"></textarea>
        </div>
        <div class="form-footer">
          <button type="submit" class="btn btn-primary btn-lg btn-full" id="submitBtn">Send Message — Free Consultation</button>
          <p class="form-privacy">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Your information is kept strictly confidential and complies with POPIA.
          </p>
        </div>
        <div class="form-success" id="formSuccess" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>
          <h3>Thank You!</h3>
          <p>We've received your message and will be in touch within 24 hours.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  MAP & LOCATION                            -->
  <!-- ══════════════════════════════════════════ -->
  <section class="map-section">
    <div class="map-embed">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d13822.4!2d30.2323!3d-29.4778!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1ef7c0c0c0c0c0c1%3A0x0!2sHowick%2C+KwaZulu-Natal!5e0!3m2!1sen!2sza!4v1"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Any Debt Collections — Howick, KZN"
      ></iframe>
    </div>
    <div class="map-info">
      <div class="map-info-inner">
        <span class="eyebrow">Find Us</span>
        <h3>Howick, KwaZulu-Natal</h3>
        <p>South Africa</p>
        <div class="map-divider"></div>
        <p class="map-national">We serve clients nationwide across all 9 provinces of South Africa.</p>
        <a href="tel:+27621165638" class="map-phone">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.47 2 2 0 0 1 3.59 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.68a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
          062 116 5638
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  TRUST BAR                                 -->
  <!-- ══════════════════════════════════════════ -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <span class="trust-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Your data is safe with us
      </span>
      <span class="trust-bar-divider" aria-hidden="true">·</span>
      <span class="trust-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        POPIA compliant
      </span>
      <span class="trust-bar-divider" aria-hidden="true">·</span>
      <span class="trust-bar-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9,11 12,14 22,4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        Reg. 2025/184330/07
      </span>
    </div>
  </div>

</BaseLayout>

<!-- Contact form submit handler -->
<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const success = document.getElementById('formSuccess') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.style.display = 'none';
        if (success) {
          success.hidden = false;
          success.focus();
        }
      } else {
        submitBtn.textContent = 'Something went wrong — please try again';
        submitBtn.disabled = false;
      }
    } catch {
      submitBtn.textContent = 'Network error — please try again';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  /* ── HERO ──────────────────────────────────── */
  .contact-hero {
    background-color: var(--color-navy);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .contact-hero-inner {
    position: relative;
    z-index: 1;
  }
  .contact-hero .eyebrow {
    color: rgba(255, 255, 255, 0.6);
  }
  .contact-hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 400;
    color: white;
    margin: 0 0 1rem;
    line-height: 1.1;
  }
  .contact-hero-sub {
    font-size: 1.1875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  .hero-watermark {
    position: absolute;
    right: -4rem;
    bottom: -3rem;
    width: 340px;
    height: 400px;
    color: rgba(255, 255, 255, 0.04);
    pointer-events: none;
  }

  /* ── CONTACT METHOD CARDS ───────────────────── */
  .contact-methods-section {
    background-color: var(--color-warm-50);
  }
  .contact-methods-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .contact-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }
  .contact-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }
  .contact-card-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .contact-card-icon.navy {
    background-color: var(--color-navy-tint);
    color: var(--color-navy);
  }
  .contact-card-icon.crimson {
    background-color: rgba(192, 57, 43, 0.08);
    color: var(--color-crimson);
  }
  .contact-card-icon.whatsapp {
    background-color: rgba(37, 211, 102, 0.1);
    color: var(--color-whatsapp);
  }
  .contact-card-title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--color-navy);
    margin: 0;
  }
  .contact-card-desc {
    font-size: 0.9375rem;
    color: var(--color-warm-600);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }
  .contact-card-links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: auto;
  }
  .contact-phone-link,
  .contact-email-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
    text-decoration: none;
    transition: color 0.2s;
  }
  .contact-phone-link:hover,
  .contact-email-link:hover {
    color: var(--color-crimson);
  }
  .btn-whatsapp {
    background-color: var(--color-whatsapp);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.35);
    cursor: pointer;
    margin-top: auto;
  }
  .btn-whatsapp:hover {
    background-color: #20c55a;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.45);
  }

  /* ── CONTACT FORM ───────────────────────────── */
  .contact-form-section {
    background-color: var(--color-ivory);
  }
  .contact-form-wrap {
    max-width: 840px;
  }
  .contact-form {
    background: white;
    border-radius: var(--radius-xl);
    padding: 2.5rem;
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0;
  }
  .form-group label {
