---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<BaseLayout
  title="About Us | Any Debt Collections — Registered South African Debt Collection Agency"
  description="Learn about Any Collections Pty Ltd (Reg. 2025/184330/07), a registered South African debt collection agency based in Howick, KZN. Meet our team, our values, and our mission."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="about-hero">
    <div class="container about-hero-inner">
      <span class="eyebrow reveal">Our Story</span>
      <h1 class="about-hero-heading reveal delay-1">
        South Africa's Most Determined<br />Debt Collectors
      </h1>
      <p class="about-hero-sub reveal delay-2">
        Registered. Relentless. Results-driven.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  WHO WE ARE                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad who-we-are">
    <div class="container who-inner">

      <div class="who-text reveal-left">
        <span class="eyebrow">Who We Are</span>
        <h2 class="section-heading who-heading">
          A Registered Agency Built on Results
        </h2>
        <p class="who-body">
          Any Collections Pty Ltd — trading as Any Debt Collections — is a fully registered South African debt collection agency dedicated to recovering outstanding balances for our clients. We serve schools, medical and dental practices, and businesses of all sizes, operating nationwide from our base in Howick, KwaZulu-Natal.
        </p>
        <p class="who-body">
          We were founded on a simple conviction: your outstanding accounts deserve professional, persistent, and ethical attention. Too many businesses write off debt they could recover. We exist to change that — one account at a time.
        </p>
        <p class="who-body">
          Our model is entirely risk-free for clients. We work on a commission basis only, meaning you pay nothing upfront and nothing if we don't collect. Every rand we recover goes back to you, deposited directly into your account on a monthly basis.
        </p>
      </div>

      <aside class="who-facts-card reveal-right delay-1">
        <h3 class="facts-title">Company Details</h3>
        <ul class="facts-list">
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            </span>
            <div>
              <span class="facts-label">Legal Name</span>
              <span class="facts-value">Any Collections Pty Ltd</span>
            </div>
          </li>
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </span>
            <div>
              <span class="facts-label">Registration Number</span>
              <span class="facts-value mono">2025/184330/07</span>
            </div>
          </li>
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <span class="facts-label">Location</span>
              <span class="facts-value">Howick, KwaZulu-Natal</span>
            </div>
          </li>
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </span>
            <div>
              <span class="facts-label">Established</span>
              <span class="facts-value">2025</span>
            </div>
          </li>
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <div>
              <span class="facts-label">Coverage</span>
              <span class="facts-value">Nationwide — South Africa</span>
            </div>
          </li>
          <li class="facts-item">
            <span class="facts-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </span>
            <div>
              <span class="facts-label">Fee Model</span>
              <span class="facts-value">Commission-based — no upfront fees</span>
            </div>
          </li>
        </ul>
      </aside>

    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  MEET THE TEAM                            -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad team-section">
    <div class="container">
      <div class="team-header reveal">
        <span class="eyebrow">Meet the Team</span>
        <h2 class="section-heading team-heading">
          The Person Behind Your Account
        </h2>
        <p class="team-intro">
          When you work with Any Debt Collections, you're not passed between call centre agents. You deal directly with the principal — someone who is personally accountable for your results.
        </p>
      </div>

      <div class="team-card-wrap">
        <article class="team-card reveal delay-1">
          <div class="team-photo-wrap">
            <div class="team-photo-placeholder" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
          </div>
          <div class="team-info">
            <h3 class="team-name">Angelique van Biljon</h3>
            <p class="team-role">Director &amp; Principal Collector</p>
            <p class="team-bio">
              Angelique founded Any Collections Pty Ltd with a clear purpose: to give businesses a professional, no-risk route to recovering the money they're owed. She manages every client relationship personally and brings a persistent, methodical approach to every account placed under her care. With deep knowledge of South African debt law, POPIA compliance, and credit bureau procedures, Angelique ensures your debtors are pursued through every legitimate channel available.
            </p>
            <ul class="team-contact-list">
              <li class="team-contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
                <a href="tel:+27621165638" class="team-contact-link">062 116 5638</a>
              </li>
              <li class="team-contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.81a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.03z"/></svg>
                <a href="tel:+27814158260" class="team-contact-link">081 415 8260</a>
              </li>
              <li class="team-contact-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:anycollections@outlook.com" class="team-contact-link">anycollections@outlook.com</a>
              </li>
            </ul>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  OUR VALUES                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad values-section">
    <div class="container">
      <div class="values-header reveal">
        <span class="eyebrow">What We Stand For</span>
        <h2 class="section-heading values-heading">Our Values</h2>
        <p class="values-intro">
          Every decision we make — from how we contact a debtor to how we report to you — is guided by four core principles.
        </p>
      </div>

      <div class="values-grid">

        <div class="value-tile reveal delay-1">
          <div class="value-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="value-title">Integrity</h3>
          <p class="value-desc">
            We operate within the bounds of South African law at all times. No threats, no harassment, no shortcuts. Just legitimate, professional debt recovery that you can be proud to associate with your business.
          </p>
        </div>

        <div class="value-tile reveal delay-2">
          <div class="value-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3 class="value-title">Transparency</h3>
          <p class="value-desc">
            You will always know exactly where your accounts stand. Monthly reports detail every action taken, every contact made, and every rand collected — no guesswork, no surprises.
          </p>
        </div>

        <div class="value-tile reveal delay-3">
          <div class="value-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
          </div>
          <h3 class="value-title">Persistence</h3>
          <p class="value-desc">
            We don't make one call and move on. We follow structured contact schedules, escalate to credit bureau listings when necessary, and trace debtors who have relocated — because your money is worth the effort.
          </p>
        </div>

        <div class="value-tile reveal delay-4">
          <div class="value-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3 class="value-title">Compliance</h3>
          <p class="value-desc">
            We are fully POPIA compliant and handle all debtor data with the care required by South African privacy law. Your clients' information — and yours — is protected at every step of the process.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  WHY WE EXIST                             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="mission-section">
    <div class="container mission-inner">
      <div class="mission-content reveal">
        <span class="eyebrow mission-eyebrow">Our Mission</span>
        <blockquote class="mission-quote">
          "Every business that has earned money deserves to be paid for it. We exist to make sure that happens — professionally, persistently, and without costing you anything unless we succeed."
        </blockquote>
        <p class="mission-attribution">— Any Collections Pty Ltd</p>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CTA                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad about-cta">
    <div class="container about-cta-inner reveal">
      <h2 class="section-heading about-cta-heading">
        Ready to Work With Us?
      </h2>
      <p class="about-cta-sub">
        Book a free, no-obligation consultation and let's talk about the accounts you need recovered. No upfront fees. No risk. Just results.
      </p>
      <div class="about-cta-btns">
        <a href={`${base}contact`} class="btn btn-primary btn-lg">Book Free Consultation</a>
        <a href={`${base}services`} class="btn btn-outline btn-lg">Explore Our Services</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────── */
  .about-hero {
    background-color: var(--color-navy-dark);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 6rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(192,57,43,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .about-hero-inner {
    position: relative;
    z-index: 1;
  }

  .about-hero .eyebrow {
    color: var(--color-crimson);
  }

  .about-hero-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 400;
    line-height: 1.1;
    color: #fff;
    margin-block: 0 1.25rem;
  }

  .about-hero-sub {
    font-family: var(--font-mono);
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.06em;
    margin: 0;
  }

  /* ── Who We Are ───────────────────────────── */
  .who-we-are {
    background-color: var(--color-ivory);
  }

  .who-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  .who-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-block: 0 1.5rem;
  }

  .who-body {
    color: var(--color-charcoal);
    font-size: 1.0625rem;
    line-height: 1.8;
    margin-block: 0 1rem;
  }

  .who-body:last-child {
    margin-bottom: 0;
  }

  .who-facts-card {
    background: white;
    border-radius: var(--radius-xl);
    padding: 2rem;
    box-shadow: var(--shadow-lg);
    border-top: 4px solid var(--color-crimson);
    position: sticky;
    top: 6rem;
  }

  .facts-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-navy);
    margin-block: 0 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-warm-100);
  }

  .facts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .facts-item {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .facts-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background-color: var(--color-navy-tint);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-navy);
    margin-top: 2px;
  }

  .facts-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-warm-600);
    margin-bottom: 0.2rem;
  }

  .facts-value {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-charcoal);
    line-height: 1.4;
  }

  .facts-value.mono {
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  /* ── Team ─────────────────────────────────── */
  .team-section {
    background-color: var(--color-warm-50);
  }

  .team-header {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .team-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-block: 0 1rem;
  }

  .team-intro {
    color: var(--color-warm-600);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin: 0;
  }

  .team-card-wrap {
    display: flex;
    justify-content: center;
  }

  .team-card {
    background: white;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    max-width: 780px;
    width: 100%;
    display: grid;
    grid-template-columns: 260px 1fr;
  }

  .team-photo-wrap {
    background: linear-gradient(160deg, var(--color-navy) 0%, var(--color-navy-dark) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
  }

  .team-photo-placeholder {
    width: 100px;
    height: 100px;
    background: rgba(255,255,255,0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.5);
  }

  .team-info {
    padding: 2.5rem;
  }

  .team-name {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-navy);
    margin-block: 0 0.25rem;
  }

  .team-role {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin-block: 0 1.25rem;
  }

  .team-bio {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-charcoal);
    margin-block: 0 1.75rem;
  }

  .team-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-warm-100);
  }

  .team-contact-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-warm-600);
  }

  .team-contact-item svg {
    flex-shrink: 0;
    color: var(--color-navy);
  }

  .team-contact-link {
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .team-contact-link:hover {
    color: var(--color-crimson);
  }

  /* ── Values ───────────────────────────────── */
  .values-section {
    background-color: var(--color-ivory);
  }

  .values-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .values-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-block: 0 1rem;
  }

  .values-intro {
    color: var(--color-warm-600);
    font-size: 1.0625rem;
    line-height: 1.7;
    margin: 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .value-tile {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-sm);
    border-bottom: 3px solid transparent;
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  .value-tile:hover {
    border-bottom-color: var(--color-crimson);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .value-icon {
    width: 54px;
    height: 54px;
    background-color: var(--color-navy-tint);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }

  .value-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-navy);
    margin-block: 0 0.75rem;
  }

  .value-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-warm-600);
    margin: 0;
  }

  /* ── Mission ──────────────────────────────── */
  .mission-section {
    background-color: var(--color-navy-dark);
    padding-block: 6rem;
    position: relative;
    overflow: hidden;
  }

  .mission-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(192,57,43,0.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .mission-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .mission-eyebrow {
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.2em;
  }

  .mission-quote {
    font-family: var(--font-serif);
