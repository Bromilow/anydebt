<style>
  /* ── Hero ──────────────────────────────────── */
  .faq-hero {
    background-color: var(--color-navy);
    background-image:
      radial-gradient(ellipse at 70% 30%, rgba(192,57,43,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 15% 80%, rgba(255,255,255,0.04) 0%, transparent 50%);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .faq-hero__inner {
    position: relative;
    z-index: 1;
  }

  .eyebrow--white {
    color: rgba(255,255,255,0.65);
  }

  .faq-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: white;
    line-height: 1.1;
    margin-block: 0 1.25rem;
  }

  .faq-hero__sub {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.75);
    max-width: 580px;
    margin-inline: auto;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .faq-hero__cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .faq-hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .faq-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  /* ── Jump Nav ──────────────────────────────── */
  .faq-jump {
    background: white;
    border-bottom: 1px solid var(--color-warm-100);
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: var(--shadow-sm);
  }

  .faq-jump__inner {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .faq-jump__inner::-webkit-scrollbar {
    display: none;
  }

  .faq-jump__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1.25rem 1.75rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-warm-600);
    text-decoration: none;
    border-bottom: 3px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .faq-jump__link:hover {
    color: var(--color-navy);
    border-bottom-color: var(--color-crimson);
  }

  /* ── FAQ Section ───────────────────────────── */
  .faq-section {
    background-color: var(--color-ivory);
  }

  .faq-section--alt {
    background-color: var(--color-warm-50);
  }

  .faq-category-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .faq-category-icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    background-color: rgba(192,57,43,0.1);
    color: var(--color-crimson);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .faq-category-icon--navy {
    background-color: var(--color-navy-tint);
    color: var(--color-navy);
  }

  .faq-category-icon--espresso {
    background-color: rgba(61,31,18,0.08);
    color: var(--color-espresso);
  }

  .faq-category-header .eyebrow {
    margin-bottom: 0.25rem;
  }

  .faq-category-header .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    margin: 0;
  }

  /* ── FAQ List & Items ──────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .faq-item {
    background: white;
  }

  .faq-item__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-navy);
    transition: background-color 0.2s ease;
    line-height: 1.4;
  }

  .faq-item__question:hover {
    background-color: var(--color-navy-tint);
  }

  .faq-item__question[aria-expanded="true"] {
    background-color: var(--color-navy-tint);
    color: var(--color-navy);
  }

  .faq-item__q-text {
    flex: 1;
  }

  .faq-item__icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-warm-50);
    color: var(--color-crimson);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease, background-color 0.2s ease;
  }

  .faq-item__question[aria-expanded="true"] .faq-item__icon {
    transform: rotate(180deg);
    background-color: var(--color-crimson);
    color: white;
  }

  .faq-item__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
  }

  .faq-item__answer.open {
    grid-template-rows: 1fr;
  }

  .faq-item__answer > p {
    overflow: hidden;
    padding: 0 2rem 1.75rem;
    margin: 0;
    color: var(--color-warm-600);
    font-size: 0.9375rem;
    line-height: 1.8;
    min-height: 0;
  }

  /* ── Bottom CTA ────────────────────────────── */
  .faq-cta {
    background-color: var(--color-navy);
    padding-block: 5rem;
  }

  .faq-cta__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2.5rem;
    align-items: center;
  }

  .faq-cta__icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .faq-cta__text {
    color: white;
  }

  .faq-cta__heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 400;
    color: white;
    margin-bottom: 0.625rem;
  }

  .faq-cta__text p {
    color: rgba(255,255,255,0.75);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .faq-cta__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .faq-cta__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .faq-cta__icon {
      margin-inline: auto;
    }

    .faq-cta__actions {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
