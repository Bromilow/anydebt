  @media (max-width: 640px) {
    .faq-hero {
      padding-top: calc(36px + 84px + 3rem);
      padding-bottom: 4rem;
    }

    .faq-hero__cta {
      flex-direction: column;
    }

    .faq-hero__cta .btn {
      width: 100%;
    }

    .faq-item__question {
      padding: 1.25rem 1.25rem;
      font-size: 0.9375rem;
    }

    .faq-item__answer > p {
      padding: 0 1.25rem 1.5rem;
    }

    .faq-cta__actions {
      flex-direction: column;
      width: 100%;
    }

    .faq-cta__actions .btn {
      width: 100%;
    }
  }
</style>

<script>
  // FAQ accordion behaviour
  document.querySelectorAll('.faq-item__question').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls');
      const answer = answerId ? document.getElementById(answerId) : null;

      // Close all in same section
      const section = btn.closest('.faq-list');
      if (section) {
        section.querySelectorAll('.faq-item__question').forEach((otherBtn) => {
          if (otherBtn !== btn) {
            otherBtn.setAttribute('aria-expanded', 'false');
            const otherId = otherBtn.getAttribute('aria-controls');
            const otherAnswer = otherId ? document.getElementById(otherId) : null;
            otherAnswer?.classList.remove('open');
          }
        });
      }

      // Toggle current
      if (expanded) {
        btn.setAttribute('aria-expanded', 'false');
        answer?.classList.remove('open');
      } else {
        btn.setAttribute('aria-expanded', 'true');
        answer?.classList.add('open');
      }
    });
  });
</script>
