<style>
  .site-footer {
    background-color: var(--color-espresso);
    color: white;
    font-family: var(--font-sans);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.25fr;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .footer-logo {
    filter: brightness(0) invert(1);
    height: 52px;
    width: auto;
    margin-bottom: 1rem;
  }
  .footer-tagline {
    font-size: 0.875rem;
    opacity: 0.65;
    margin: 0 0 0.5rem;
    line-height: 1.5;
  }
  .footer-reg {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    opacity: 0.45;
    margin: 0;
  }

  .footer-col-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-crimson);
    margin: 0 0 1rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links a {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: white; }

  .footer-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .footer-contact a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-contact a:hover { color: white; }
  .footer-location {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
  }
  .footer-location svg { flex-shrink: 0; margin-top: 2px; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 1.25rem;
  }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy {
    margin: 0;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.35);
  }
  .footer-legal-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.3);
  }
  .footer-legal-links a {
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-legal-links a:hover { color: white; }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      padding-top: 3rem;
      padding-bottom: 3rem;
    }
    .footer-brand { grid-column: auto; }
    .footer-bottom-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
