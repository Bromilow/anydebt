---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="School Fee Recovery | Any Debt Collections"
  description="Ethical, effective school fee recovery for South African schools. We recover outstanding fees while protecting parent relationships and your school's reputation. No upfront fees."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="schools-hero" id="hero" aria-label="Schools debt recovery hero">
    <div class="container schools-hero__inner">
      <div class="schools-hero__content">
        <span class="eyebrow eyebrow--red">Schools &amp; Education</span>
        <h1 class="schools-hero__heading">
          School Fee Recovery — Ethical, Effective, and Reputation-Preserving
        </h1>
        <p class="schools-hero__sub">
          Outstanding school fees don't just affect your balance sheet — they disrupt every aspect of how your school operates. We recover what you're owed while treating your community with dignity.
        </p>
        <div class="schools-hero__ctas">
          <a href="/contact" class="btn btn-primary btn-lg">Free Consultation for Schools</a>
          <a href="/how-it-works" class="btn btn-outline-white btn-lg">How It Works</a>
        </div>
      </div>
      <div class="schools-hero__badge" aria-hidden="true">
        <div class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 20h20"/>
            <path d="M4 20V10l8-6 8 6v10"/>
            <path d="M9 20v-5h6v5"/>
          </svg>
          <span class="hero-badge__label">Schools &amp; Education</span>
        </div>
      </div>
    </div>
    <div class="schools-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="var(--color-ivory)"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  THE CHALLENGE                             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad challenge-section" aria-labelledby="challenge-heading">
    <div class="container">
      <div class="challenge-intro reveal">
        <span class="eyebrow">The Challenge Schools Face</span>
        <h2 class="section-heading" id="challenge-heading">When Fees Go Unpaid, Everything Suffers</h2>
        <p class="challenge-intro__sub">
          School fee arrears create a cascade of problems that go far beyond accounting. Here's the reality facing South African school administrators every day.
        </p>
      </div>

      <div class="challenge-grid">
        <div class="challenge-card reveal delay-1" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Budget Planning Disruption</h3>
          <p class="challenge-card__desc">Unpredictable income makes it impossible to plan staffing levels, facility upgrades, or educational resources. Every unpaid account creates a gap in your annual budget.</p>
        </div>

        <div class="challenge-card reveal delay-2" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Government Funding Formulas Affected</h3>
          <p class="challenge-card__desc">Many government subsidies and funding allocations are calculated partly on enrolment and fee-paying status. High arrears can indirectly affect the funding your school qualifies for.</p>
        </div>

        <div class="challenge-card reveal delay-3" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="17"/>
              <line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Staff Morale and Retention</h3>
          <p class="challenge-card__desc">When cash flow is tight due to unpaid fees, salary increases are delayed, benefit programs are cut, and excellent teachers leave. Fee recovery directly impacts your ability to retain quality staff.</p>
        </div>

        <div class="challenge-card reveal delay-4" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Supplier &amp; Service Payments at Risk</h3>
          <p class="challenge-card__desc">Stationery suppliers, maintenance contractors, cleaning services, and transport providers — all depend on timely payment. Arrears put essential school services in jeopardy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  HOW WE HELP                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad how-section" aria-labelledby="how-heading">
    <div class="container">
      <div class="how-inner">
        <div class="how-text reveal-left">
          <span class="eyebrow">Our Approach for Schools</span>
          <h2 class="section-heading" id="how-heading">Recovery That Respects Your Community</h2>
          <p>Schools are not just businesses — they are communities. Every family in arrears is also a parent, a neighbour, a community member. Our approach acknowledges this reality.</p>
          <p>We begin with respectful, professional communication that firmly but courteously requests payment. Our tone is never threatening or demeaning — we represent your school as you would want it represented.</p>
          <p>Where genuine hardship exists, we facilitate structured payment arrangements that protect the relationship while still recovering what is owed. Our goal is always resolution, not confrontation.</p>
        </div>
        <div class="how-steps reveal-right">
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">01</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Free Consultation &amp; Account Review</h3>
              <p>We assess your arrears portfolio at no charge, identify the best recovery strategy, and explain exactly how we'll proceed — before you commit to anything.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">02</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Respectful Initial Contact</h3>
              <p>Parents receive professional, courteous communication on your behalf. We handle all contact so your staff can focus on education, not debt chasing.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">03</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Payment Arrangements &amp; Escalation</h3>
              <p>Where appropriate, we structure manageable payment plans. For non-responsive accounts, we escalate using all legal means available.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">04</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Monthly Settlement to Your School</h3>
              <p>All recovered funds are paid directly to your school every month. You receive regular progress reports on every account we are pursuing.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  KEY BENEFITS                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad benefits-section" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="benefits-intro reveal">
        <span class="eyebrow">Why Schools Choose Us</span>
        <h2 class="section-heading" id="benefits-heading">Built Around Your School's Needs</h2>
      </div>
      <ul class="benefits-list" role="list">
        <li class="benefit-item reveal delay-1" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Zero Upfront Cost</strong>
            <p>You pay nothing until we recover. Our commission comes from collected funds only — making this a zero-risk investment for your school.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-2" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Reputation Protection</strong>
            <p>Our firm-but-fair communication style ensures parents are never humiliated or treated poorly. Your school's good name is protected at every step.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-3" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>POPIA Compliant Data Handling</strong>
            <p>All parent and student data is handled in strict accordance with the Protection of Personal Information Act. No privacy violations, ever.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-4" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Free Staff from Admin Burden</strong>
            <p>Your administrators spend hours chasing payments. We take that burden away entirely — freeing your team to support students, not debtors.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-5" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Nationwide Tracing Services</strong>
            <p>When parents move without notice, we can trace them across South Africa. No debtor escapes our reach simply by moving to another province.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-6" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Regular Transparent Reporting</strong>
            <p>Monthly reports keep you informed of every account's status. No black boxes — just clear, honest progress updates you can share with your board.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CROSS-LINKS TO OTHER INDUSTRIES           -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad crosslinks-section" aria-labelledby="crosslinks-heading">
    <div class="container">
      <div class="crosslinks-inner">
        <div class="reveal">
          <span class="eyebrow">Industries We Also Serve</span>
          <h2 class="section-heading" id="crosslinks-heading">Not a School? We Can Still Help.</h2>
          <p class="crosslinks-sub">Any Debt Collections works with organisations of every type. Explore our other specialisations or get in touch to discuss your specific situation.</p>
        </div>
        <div class="crosslinks-grid">
          <a href="/industries/medical" class="crosslink-card reveal delay-1" aria-label="Debt recovery for doctors and dentists">
            <div class="crosslink-card__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div>
              <strong>Doctors &amp; Dentists</strong>
              <p>Medical debt recovery that respects patients and HPCSA ethics.</p>
            </div>
            <svg class="crosslink-card__arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/industries/business" class="crosslink-card reveal delay-2" aria-label="Debt recovery for businesses">
            <div class="crosslink-card__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            </div>
            <div>
              <strong>Business Collections</strong>
              <p>B2B and B2C debt recovery for businesses of every size.</p>
            </div>
            <svg class="crosslink-card__arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CTA SECTION                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="schools-cta" aria-label="Free consultation call to action">
    <div class="container">
      <div class="schools-cta__inner reveal">
        <span class="eyebrow eyebrow--red">No Upfront Fees — Zero Risk</span>
        <h2 class="schools-cta__heading">Ready to Recover Your School's Fees?</h2>
        <p class="schools-cta__sub">
          Book a free, no-obligation consultation with Angelique. We'll review your outstanding accounts, explain our approach, and give you a clear picture of what we can recover — before you commit to anything.
        </p>
        <div class="schools-cta__actions">
          <a href="/contact" class="btn btn-primary btn-lg">Book Free Consultation</a>
          <div class="schools-cta__contact">
            <span>Or call directly:</span>
            <a href="tel:+27621165638" class="schools-cta__tel">062 116 5638</a>
            <span aria-hidden="true">·</span>
            <a href="tel:+27814158260" class="schools-cta__tel">081 415 8260</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────── */
  .schools-hero {
    background-color: var(--color-navy);
    background-image:
      radial-gradient(ellipse at 80% 20%, rgba(192,57,43,0.15) 0%, transparent 55%),
      radial-gradient(ellipse at 5% 90%, rgba(255,255,255,0.03) 0%, transparent 50%);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
  }

  .schools-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .eyebrow--red {
    color: var(--color-crimson);
  }

  .schools-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 400;
    color: white;
    line-height: 1.15;
    margin-block: 0 1.25rem;
  }

  .schools-hero__sub {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.8);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .schools-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-badge {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: white;
    text-align: center;
    padding: 1.5rem;
  }

  .hero-badge__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .schools-hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .schools-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  /* ── Challenge Section ─────────────────────── */
  .challenge-section {
    background-color: var(--color-ivory);
  }

  .challenge-intro {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .challenge-intro__sub {
    color: var(--color-warm-600);
    font-size: 1.0625rem;
    margin-top: 1rem;
    line-height: 1.7;
  }

  .challenge-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .challenge-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--color-crimson);
    transition: box-shadow 0.25s ease;
  }

  .challenge-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .challenge-card__icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background-color: var(--color-navy-tint);
    color: var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .challenge-card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
    font-weight: 400;
  }

  .challenge-card__desc {
    color: var(--color-warm-600);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
  }

  /* ── How We Help ───────────────────────────── */
  .how-section {
    background-color: var(--color-warm-50);
  }

  .how-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .how-text p {
    color: var(--color-warm-600);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .how-text .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .how-step {
    display: flex;
    gap: 1.25rem;
    padding-bottom: 2rem;
    position: relative;
  }

  .how-step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.375rem;
    top: 2.75rem;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-navy-tint), transparent);
  }

  .how-step__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: white;
    background-color: var(--color-navy);
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }

  .how-step__title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
  }

  .how-step__content p {
    color: var(--color-warm-600);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Benefits Section ──────────────────────── */
  .benefits-section {
    background-color: var(--color-ivory);
  }

  .benefits-intro {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .benefits-intro .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s ease;
  }

  .benefit-item:hover {
    box-shadow: var(--shadow-md);
  }

  .benefit-item__icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: var(--color-crimson);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .benefit-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 0.375rem;
  }

  .benefit-item p {
    font-size: 0.875rem;
    color: var(--color-warm-600);
    margin: 0;
    line-height: 1.65;
  }

  /* ── Cross-links ───────────────────────────── */
  .crosslinks-section {
    background-color: var(--color-warm-50);
  }

  .crosslinks-inner {
