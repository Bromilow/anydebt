<style>
  .topbar {
    background-color: var(--color-crimson);
    color: white;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1;
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.625rem;
    gap: 1rem;
  }
  .topbar-contacts {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .topbar-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: white;
    text-decoration: none;
    opacity: 0.9;
    transition: opacity 0.15s;
  }
  .topbar-link:hover { opacity: 1; }
  .topbar-divider {
    opacity: 0.4;
    font-size: 0.75rem;
  }
  .topbar-tagline {
    margin: 0;
    opacity: 0.75;
    white-space: nowrap;
    font-size: 0.75rem;
  }
  @media (max-width: 640px) {
    .topbar-tagline { display: none; }
    .topbar-hide-sm { display: none; }
    .topbar-contacts { gap: 0.5rem; }
  }
</style>
