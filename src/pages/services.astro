---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<BaseLayout
  title="Our Services | Any Debt Collections — Full-Spectrum Debt Recovery, South Africa"
  description="Any Debt Collections offers professional debt collection, credit bureau listings, tracing, follow-ups, monthly reporting, direct payments, and CRM — nationwide, no upfront fees."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                     -->
  <!-- ══════════════════════════════════════════ -->
  <section class="services-hero">
    <div class="container services-hero-inner">
      <span class="eyebrow reveal">What We Do</span>
      <h1 class="services-hero-heading reveal delay-1">
        Every Tool You Need to Recover<br />What's Yours
      </h1>
      <p class="services-hero-sub reveal delay-2">
        From first letter to final payment, we deploy a full spectrum of professional recovery techniques. Commission-based — you only pay when we collect.
      </p>
      <div class="services-nav reveal delay-3">
        <a href="#debt-collection" class="services-nav-pill">Debt Collection</a>
        <a href="#credit-bureau" class="services-nav-pill">Credit Bureau</a>
        <a href="#tracing" class="services-nav-pill">Tracing</a>
        <a href="#follow-ups" class="services-nav-pill">Follow-Ups</a>
        <a href="#reporting" class="services-nav-pill">Reporting</a>
        <a href="#payments" class="services-nav-pill">Payments</a>
        <a href="#crm" class="services-nav-pill">CRM</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 1: DEBT COLLECTION               -->
  <!-- ══════════════════════════════════════════ -->
  <section id="debt-collection" class="service-section light">
    <div class="container service-inner">
      <div class="service-text reveal-left">
        <div class="service-icon-wrap" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <span class="service-number">01</span>
        <h2 class="service-heading">Debt Collection</h2>
        <p class="service-body">
          Our core service — and the foundation of everything we do. When a debtor stops paying, we take over the recovery process so you don't have to. We handle the follow-up calls, written demands, and escalation sequences that most businesses simply don't have the time or systems to manage.
        </p>
        <p class="service-body">
          Our approach is systematic and relentless. Every account placed with us receives a structured contact programme — from initial letters and calls through to formal demand notices. We apply progressive pressure through legitimate channels, escalating appropriately when debtors are unresponsive. At every point, we maintain a professional tone that protects your business's reputation.
        </p>
        <p class="service-body">
          We serve schools chasing unpaid fees, doctors and dentists owed for consultations and procedures, and businesses dealing with commercial debtors. Regardless of the account type or amount, every case receives the same focused attention.
        </p>
        <ul class="service-benefits">
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Commission-based — zero cost if we don't collect
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Structured escalation — letters, calls, formal demands
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Professional tone — your brand reputation is protected
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            All industries: schools, medical, commercial
          </li>
        </ul>
        <a href={`${base}contact`} class="btn btn-primary">Start Collecting Today</a>
      </div>

      <div class="service-visual reveal-right delay-2">
        <div class="service-stat-card">
          <div class="stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <p class="stat-label">Systematic. Ethical. Results-driven.</p>
          <p class="stat-desc">Every account receives a structured recovery programme with documented escalation steps and consistent follow-through.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill">Letters &amp; Demands</span>
          <span class="service-pill">Phone Follow-Ups</span>
          <span class="service-pill">Nationwide Coverage</span>
          <span class="service-pill">All Account Sizes</span>
          <span class="service-pill">POPIA Compliant</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 2: CREDIT BUREAU LISTINGS        -->
  <!-- ══════════════════════════════════════════ -->
  <section id="credit-bureau" class="service-section dark">
    <div class="container service-inner reverse">
      <div class="service-visual reveal-left delay-2">
        <div class="service-stat-card dark-card">
          <div class="stat-icon dark-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <p class="stat-label dark-label">A powerful motivator to pay</p>
          <p class="stat-desc dark-desc">Credit bureau listings impact a debtor's ability to access credit, secure housing, and apply for services — creating powerful incentive to settle.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill dark-pill">Bureau Listing</span>
          <span class="service-pill dark-pill">Legal Leverage</span>
          <span class="service-pill dark-pill">Consumer Impact</span>
          <span class="service-pill dark-pill">Dispute Resolution</span>
        </div>
      </div>

      <div class="service-text reveal-right">
        <div class="service-icon-wrap dark-icon-wrap" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <span class="service-number dark-number">02</span>
        <h2 class="service-heading dark-heading">Credit Bureau Listings</h2>
        <p class="service-body dark-body">
          When a debtor refuses to engage or ignores repeated contact attempts, a credit bureau listing becomes one of the most effective tools available. We handle the listing process on your behalf, ensuring non-paying debtors are recorded on South Africa's credit bureaus in accordance with the National Credit Act.
        </p>
        <p class="service-body dark-body">
          The impact of a bureau listing is significant. It affects a debtor's credit score, limits their ability to access new credit, secure rental agreements, or obtain services that require creditworthiness checks. This creates a powerful and entirely legitimate incentive for the debtor to settle the outstanding balance — often prompting action where previous contact attempts had failed.
        </p>
        <p class="service-body dark-body">
          We manage the full process: notification to the debtor, submission to the bureau, and removal once the account is settled. You are kept informed throughout, and the outcome is documented in your monthly report.
        </p>
        <ul class="service-benefits dark-benefits">
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Compliant with the National Credit Act
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Full listing-to-removal process managed for you
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Effective against persistent non-payers
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Documented and reported monthly
          </li>
        </ul>
        <a href={`${base}contact`} class="btn btn-outline-white">Enquire About Bureau Listings</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 3: TRACING                       -->
  <!-- ══════════════════════════════════════════ -->
  <section id="tracing" class="service-section light">
    <div class="container service-inner">
      <div class="service-text reveal-left">
        <div class="service-icon-wrap" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <span class="service-number">03</span>
        <h2 class="service-heading">Tracing Services</h2>
        <p class="service-body">
          Some debtors don't just avoid paying — they disappear. They change phone numbers, move addresses, and make themselves impossible to contact through the information you have on file. Our skip-tracing service is designed to find them.
        </p>
        <p class="service-body">
          We use legitimate investigative methods and access to South Africa's available data infrastructure to locate debtors who have relocated, changed contact details, or otherwise made themselves unreachable. Our tracing capabilities extend nationwide — wherever the debtor has moved, we work to find them.
        </p>
        <p class="service-body">
          Once a debtor is traced, we resume the standard recovery process immediately. Tracing is integrated into our overall collection workflow, so there's no gap in the recovery effort and no delay in picking up where we left off.
        </p>
        <ul class="service-benefits">
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Nationwide skip-tracing coverage
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Integrated seamlessly into recovery workflow
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            No interruption in collection once traced
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Legitimate methods, POPIA compliant
          </li>
        </ul>
        <a href={`${base}contact`} class="btn btn-primary">Trace a Missing Debtor</a>
      </div>

      <div class="service-visual reveal-right delay-2">
        <div class="service-stat-card">
          <div class="stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <p class="stat-label">They moved. We'll find them.</p>
          <p class="stat-desc">Missing debtor contact details shouldn't mean writing off the debt. Our tracing service locates relocated debtors nationwide.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill">Skip Tracing</span>
          <span class="service-pill">Address Verification</span>
          <span class="service-pill">Contact Updates</span>
          <span class="service-pill">Nationwide</span>
          <span class="service-pill">Integrated Recovery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 4: FOLLOW-UPS                    -->
  <!-- ══════════════════════════════════════════ -->
  <section id="follow-ups" class="service-section dark">
    <div class="container service-inner reverse">
      <div class="service-visual reveal-left delay-2">
        <div class="service-stat-card dark-card">
          <div class="stat-icon dark-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <p class="stat-label dark-label">Structured. Documented. Consistent.</p>
          <p class="stat-desc dark-desc">Most debts are recovered through persistence, not luck. Our scheduled follow-up programme ensures no account goes cold.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill dark-pill">Scheduled Calls</span>
          <span class="service-pill dark-pill">Written Follow-Ups</span>
          <span class="service-pill dark-pill">Escalation Triggers</span>
          <span class="service-pill dark-pill">Full Documentation</span>
        </div>
      </div>

      <div class="service-text reveal-right">
        <div class="service-icon-wrap dark-icon-wrap" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <span class="service-number dark-number">04</span>
        <h2 class="service-heading dark-heading">Regular Follow-Ups</h2>
        <p class="service-body dark-body">
          Debt recovery is rarely a one-contact exercise. The vast majority of successful collections happen because someone kept following up — consistently, professionally, and without giving the debtor the opportunity to forget or ignore the obligation. That's exactly what we do.
        </p>
        <p class="service-body dark-body">
          We build a structured contact schedule for every account: initial contact, reminder calls at defined intervals, written follow-ups via email and letter, and escalation triggers when responses stall. Every contact is documented, timestamped, and retained as a complete record of recovery efforts.
        </p>
        <p class="service-body dark-body">
          This documented trail also serves a practical legal purpose — it demonstrates that due process has been followed if further legal steps ever become necessary. More importantly, it simply works. Consistent pressure within a structured framework is the most reliable path to recovery.
        </p>
        <ul class="service-benefits dark-benefits">
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Pre-defined contact schedules per account
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Every contact logged with date, time, and outcome
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Automatic escalation when accounts stall
          </li>
          <li class="service-benefit dark-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Admissible audit trail for legal proceedings
          </li>
        </ul>
        <a href={`${base}contact`} class="btn btn-outline-white">Put Your Accounts on a Schedule</a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 5: MONTHLY REPORTING             -->
  <!-- ══════════════════════════════════════════ -->
  <section id="reporting" class="service-section light">
    <div class="container service-inner">
      <div class="service-text reveal-left">
        <div class="service-icon-wrap" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <span class="service-number">05</span>
        <h2 class="service-heading">Monthly Reporting</h2>
        <p class="service-body">
          You should never have to wonder what is happening with your accounts. Transparency is one of our core commitments, which is why every client receives a comprehensive monthly report detailing exactly where each account stands, what actions have been taken, and what has been collected.
        </p>
        <p class="service-body">
          Our reports are clear, well-structured, and delivered on a consistent schedule. They include a status update per account, a full log of contacts made during the period, amounts collected, and any significant developments such as bureau listings or tracing updates. If an account has progressed, you'll see how. If an account is proving difficult, you'll know why and what is being done about it.
        </p>
        <p class="service-body">
          Reporting isn't just about accountability — it's about giving you the information you need to make decisions. Some clients use the reports to decide which accounts to write off, which to escalate legally, and which to continue pursuing. We provide the data. You stay in control.
        </p>
        <ul class="service-benefits">
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Per-account status updates every month
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Collections summary — amounts received vs. outstanding
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Contact log included for every account
          </li>
          <li class="service-benefit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Clear, jargon-free reporting format
          </li>
        </ul>
        <a href={`${base}contact`} class="btn btn-primary">Request a Sample Report</a>
      </div>

      <div class="service-visual reveal-right delay-2">
        <div class="service-stat-card">
          <div class="stat-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <p class="stat-label">Full visibility. Every month.</p>
          <p class="stat-desc">You'll never be left wondering. Monthly reports give you a complete picture of every account, every action, and every rand collected.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill">Status Updates</span>
          <span class="service-pill">Collection Summaries</span>
          <span class="service-pill">Contact Logs</span>
          <span class="service-pill">Action Records</span>
          <span class="service-pill">Monthly Delivery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  SERVICE 6: MONTHLY PAYMENTS              -->
  <!-- ══════════════════════════════════════════ -->
  <section id="payments" class="service-section dark">
    <div class="container service-inner reverse">
      <div class="service-visual reveal-left delay-2">
        <div class="service-stat-card dark-card">
          <div class="stat-icon dark-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <p class="stat-label dark-label">Your money, back in your account.</p>
          <p class="stat-desc dark-desc">All recovered funds are transferred directly to your bank account on a monthly basis — no delays, no complications.</p>
        </div>
        <div class="service-pill-list">
          <span class="service-pill dark-pill">Direct Bank Transfers</span>
          <span class="service-pill dark-pill">Monthly Cycle</span>
          <span class="service-pill dark-pill">Full Reconciliation</span>
          <span class="service-pill dark-pill">Commission Deducted</span>
        </div>
      </div>

      <div class="service-text reveal-right">
        <div class="service-icon-wrap dark-icon-wrap" aria-hidden="true">
