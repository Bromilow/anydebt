---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Industries We Serve | Any Debt Collections"
  description="Any Debt Collections provides tailored debt recovery for schools, medical practices, and businesses across South Africa. No upfront fees. Nationwide service."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="industries-hero" id="hero" aria-label="Industries hero">
    <div class="container industries-hero__inner">
      <span class="eyebrow eyebrow--white">Industry Expertise</span>
      <h1 class="industries-hero__heading">
        Tailored Recovery for<br />Your Sector
      </h1>
      <p class="industries-hero__sub">
        Every industry has its own dynamics, relationships, and sensitivities. Our sector-specific approach means we recover more — while protecting what matters most to your organisation.
      </p>
    </div>
    <div class="industries-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="var(--color-ivory)"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  INDUSTRY CARDS                            -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad industries-cards-section" aria-label="Industries">
    <div class="container">
      <div class="section-intro reveal">
        <span class="eyebrow">Where We Specialise</span>
        <h2 class="section-heading">Choose Your Industry</h2>
        <p class="section-intro__sub">
          Select your sector below to see how we approach debt recovery specifically for your type of organisation — the challenges you face, and the solutions we provide.
        </p>
      </div>

      <div class="industries-grid" role="list">

        <!-- Card 1: Schools -->
        <article class="industry-card reveal delay-1" role="listitem">
          <div class="industry-card__image industry-card__image--schools" aria-hidden="true">
            <div class="industry-card__image-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M2 20h20"/>
                <path d="M4 20V10l8-6 8 6v10"/>
                <path d="M9 20v-5h6v5"/>
                <rect x="10" y="4" width="4" height="4"/>
              </svg>
            </div>
            <div class="industry-card__image-label">Schools &amp; Education</div>
          </div>
          <div class="industry-card__body">
            <h3 class="industry-card__title">Schools &amp; Education</h3>
            <p class="industry-card__desc">
              School fee arrears disrupt budgets, staffing, and supplier relationships. We recover outstanding fees with sensitivity to the parent community and your school's reputation.
            </p>
            <ul class="industry-card__highlights" aria-label="Key points">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Reputation-preserving approach
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Sensitive to parent relationships
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Budget planning support
              </li>
            </ul>
            <a href="/industries/schools" class="btn btn-primary industry-card__cta" aria-label="Learn more about school fee recovery">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- Card 2: Medical -->
        <article class="industry-card reveal delay-2" role="listitem">
          <div class="industry-card__image industry-card__image--medical" aria-hidden="true">
            <div class="industry-card__image-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </div>
            <div class="industry-card__image-label">Doctors &amp; Dentists</div>
          </div>
          <div class="industry-card__body">
            <h3 class="industry-card__title">Doctors &amp; Dentists</h3>
            <p class="industry-card__desc">
              Medical practices face unique challenges: HPCSA ethical obligations, medical aid disputes, and the need to maintain patient trust. Our approach is professional, empathetic, and compliant.
            </p>
            <ul class="industry-card__highlights" aria-label="Key points">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                HPCSA ethics-conscious
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Patient-respectful communication
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Medical aid dispute resolution
              </li>
            </ul>
            <a href="/industries/medical" class="btn btn-primary industry-card__cta" aria-label="Learn more about medical debt recovery">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <!-- Card 3: Business -->
        <article class="industry-card reveal delay-3" role="listitem">
          <div class="industry-card__image industry-card__image--business" aria-hidden="true">
            <div class="industry-card__image-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                <line x1="12" y1="12" x2="12" y2="17"/>
                <line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/>
              </svg>
            </div>
            <div class="industry-card__image-label">Business Collections</div>
          </div>
          <div class="industry-card__body">
            <h3 class="industry-card__title">Business Collections</h3>
            <p class="industry-card__desc">
              Unpaid B2B invoices stifle growth and damage supplier relationships. From sole traders to corporates, we pursue outstanding commercial debt with a scalable, results-driven approach.
            </p>
            <ul class="industry-card__highlights" aria-label="Key points">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                B2B and B2C recovery
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Scalable for any volume
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Commercial debt expertise
              </li>
            </ul>
            <a href="/industries/business" class="btn btn-primary industry-card__cta" aria-label="Learn more about business debt recovery">
              Learn More
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  WHAT WE ALL SHARE                         -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad shared-section" aria-label="Our promise across all industries">
    <div class="container">
      <div class="shared-inner">
        <div class="shared-text reveal-left">
          <span class="eyebrow">Universal Commitment</span>
          <h2 class="section-heading">The Same Promise, Every Time</h2>
          <p>Regardless of which industry you're in, every client receives the same core commitment: no upfront fees, complete transparency, ethical practice, and monthly settlement of recovered funds.</p>
          <p>We operate nationwide — from Cape Town to Limpopo — and are POPIA compliant in all data handling.</p>
        </div>
        <div class="shared-pillars reveal-right">
          <div class="shared-pillar">
            <div class="shared-pillar__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <strong>No Upfront Fees</strong>
              <p>Commission-only model. We only earn when you do.</p>
            </div>
          </div>
          <div class="shared-pillar">
            <div class="shared-pillar__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <strong>Ethical &amp; POPIA Compliant</strong>
              <p>Fully registered and compliant with all South African legislation.</p>
            </div>
          </div>
          <div class="shared-pillar">
            <div class="shared-pillar__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <strong>Nationwide Service</strong>
              <p>All 9 provinces covered — wherever your debtors are.</p>
            </div>
          </div>
          <div class="shared-pillar">
            <div class="shared-pillar__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            </div>
            <div>
              <strong>Monthly Settlements</strong>
              <p>Recovered funds paid to you every month, on time.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  NOT SURE WHICH APPLIES?                   -->
  <!-- ══════════════════════════════════════════ -->
  <section class="unsure-section" aria-label="Not sure which industry applies">
    <div class="container">
      <div class="unsure-inner reveal">
        <div class="unsure-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="unsure-text">
          <h2 class="unsure-heading">Not sure which applies to you?</h2>
          <p>If someone owes you money, we can help — regardless of your sector or the size of the debt. Any Collections works with <strong>any business, any industry, anywhere in South Africa</strong>. Our free consultation is the easiest way to find out if we can help you.</p>
        </div>
        <div class="unsure-ctas">
          <a href="/contact" class="btn btn-primary btn-lg">Book Free Consultation</a>
          <a href="/how-it-works" class="btn btn-outline-white btn-lg">How It Works</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────── */
  .industries-hero {
    background-color: var(--color-navy);
    background-image:
      radial-gradient(ellipse at 70% 50%, rgba(192,57,43,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 10% 80%, rgba(255,255,255,0.04) 0%, transparent 50%);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .industries-hero__inner {
    position: relative;
    z-index: 1;
  }

  .eyebrow--white {
    color: rgba(255,255,255,0.75);
  }

  .industries-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: white;
    line-height: 1.1;
    margin-block: 0 1.25rem;
  }

  .industries-hero__sub {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.8);
    max-width: 640px;
    margin-inline: auto;
    line-height: 1.7;
  }

  .industries-hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .industries-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  /* ── Section Intro ─────────────────────────── */
  .industries-cards-section {
    background-color: var(--color-ivory);
  }

  .section-intro {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 4rem;
  }

  .section-intro__sub {
    color: var(--color-warm-600);
    font-size: 1.0625rem;
    margin-top: 1rem;
    line-height: 1.7;
  }

  /* ── Industry Grid ─────────────────────────── */
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* ── Industry Card ─────────────────────────── */
  .industry-card {
    background: white;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .industry-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-6px);
  }

  .industry-card__image {
    height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }

  .industry-card__image--schools {
    background: linear-gradient(135deg, #1E3A5F 0%, #2A4F7A 100%);
    color: white;
  }

  .industry-card__image--medical {
    background: linear-gradient(135deg, #27856A 0%, #1a6050 100%);
    color: white;
  }

  .industry-card__image--business {
    background: linear-gradient(135deg, #C0392B 0%, #A93226 100%);
    color: white;
  }

  .industry-card__image-icon {
    opacity: 0.9;
  }

  .industry-card__image-label {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .industry-card__body {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .industry-card__title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-navy);
    margin-bottom: 0.875rem;
  }

  .industry-card__desc {
    color: var(--color-warm-600);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex: 1;
  }

  .industry-card__highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .industry-card__highlights li {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--color-charcoal);
    font-weight: 500;
  }

  .industry-card__highlights li svg {
    color: var(--color-crimson);
    flex-shrink: 0;
  }

  .industry-card__cta {
    align-self: flex-start;
  }

  /* ── Shared Section ────────────────────────── */
  .shared-section {
    background-color: var(--color-warm-50);
  }

  .shared-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .shared-text p {
    color: var(--color-warm-600);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .shared-text .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }

  .shared-pillars {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .shared-pillar {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .shared-pillar__icon {
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background-color: var(--color-navy-tint);
    color: var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .shared-pillar strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 0.25rem;
  }

  .shared-pillar p {
    font-size: 0.875rem;
    color: var(--color-warm-600);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Not Sure Section ──────────────────────── */
  .unsure-section {
    background-color: var(--color-navy);
    padding-block: 5rem;
  }

  .unsure-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2.5rem;
    align-items: center;
  }

  .unsure-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .unsure-text {
    color: white;
  }

  .unsure-heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 400;
    color: white;
    margin-bottom: 0.75rem;
  }

  .unsure-text p {
    color: rgba(255,255,255,0.8);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .unsure-text strong {
    color: white;
  }

  .unsure-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 900px) {
    .industries-grid {
      grid-template-columns: 1fr;
      max-width: 540px;
      margin-inline: auto;
    }

    .shared-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .unsure-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .unsure-icon {
      margin-inline: auto;
    }

    .unsure-ctas {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .industries-hero {
      padding-top: calc(36px + 84px + 3rem);
      padding-bottom: 4rem;
    }

    .unsure-ctas {
      flex-direction: column;
      width: 100%;
    }

    .unsure-ctas .btn {
      width: 100%;
    }
  }
</style>
