---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = (import.meta.env.BASE_URL || "/").replace(/\/?$/, "/");
---

<BaseLayout
  title="Business Debt Recovery | Any Debt Collections"
  description="Commercial debt recovery for South African businesses of every size — from sole traders to corporates. B2B and B2C invoice recovery. No upfront fees. Nationwide service."
>

  <!-- ══════════════════════════════════════════ -->
  <!--  HERO                                      -->
  <!-- ══════════════════════════════════════════ -->
  <section class="business-hero" id="hero" aria-label="Business debt recovery hero">
    <div class="container business-hero__inner">
      <div class="business-hero__content">
        <span class="eyebrow eyebrow--orange">Businesses of All Sizes</span>
        <h1 class="business-hero__heading">
          Business Debt Recovery — From Sole Traders to Corporates
        </h1>
        <p class="business-hero__sub">
          Unpaid invoices are not just a cash flow problem — they are a growth problem. Every rand you're owed but haven't received is a rand that can't be reinvested in your business. We recover it.
        </p>
        <div class="business-hero__ctas">
          <a href={`${base}contact`} class="btn btn-primary btn-lg">Free Business Consultation</a>
          <a href={`${base}how-it-works`} class="btn btn-outline-white btn-lg">How It Works</a>
        </div>
      </div>
      <div class="business-hero__badge" aria-hidden="true">
        <div class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
            <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="17"/>
            <line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/>
          </svg>
          <span class="hero-badge__label">Business Collections</span>
        </div>
      </div>
    </div>
    <div class="business-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="var(--color-ivory)"/>
      </svg>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  STATS BAR                                 -->
  <!-- ══════════════════════════════════════════ -->
  <section class="stats-bar" aria-label="Business debt statistics">
    <div class="container stats-bar__inner">
      <div class="stat-item reveal delay-1">
        <span class="stat-item__num">60%+</span>
        <span class="stat-item__label">of SA SMEs report cash flow problems due to late payments</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item reveal delay-2">
        <span class="stat-item__num">90 days</span>
        <span class="stat-item__label">average age of invoices before businesses seek collection help</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item reveal delay-3">
        <span class="stat-item__num">R0</span>
        <span class="stat-item__label">upfront cost to start recovering your outstanding debt today</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  THE CHALLENGE                             -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad challenge-section" aria-labelledby="challenge-heading">
    <div class="container">
      <div class="challenge-intro reveal">
        <span class="eyebrow">The Challenge Businesses Face</span>
        <h2 class="section-heading" id="challenge-heading">When Invoices Go Unpaid, Growth Stalls</h2>
        <p class="challenge-intro__sub">
          Unpaid debt is one of the leading causes of business failure in South Africa. Here's what's really at stake when your debtors don't pay.
        </p>
      </div>

      <div class="challenge-grid">
        <div class="challenge-card reveal delay-1" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
              <line x1="1" y1="10" x2="23" y2="10"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">B2B Invoice Non-Payment</h3>
          <p class="challenge-card__desc">Business-to-business debt is a systemic problem in South Africa. A client that won't pay an invoice often knows you're reluctant to pursue them for fear of damaging the commercial relationship. We remove that hesitation by acting on your behalf professionally and at arm's length.</p>
        </div>

        <div class="challenge-card reveal delay-2" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Relationship Risk</h3>
          <p class="challenge-card__desc">Chasing payment directly can permanently damage supplier and client relationships that took years to build. Our third-party position allows us to be firm on your behalf while you maintain the relationship — clients rarely blame you for using a collection agency.</p>
        </div>

        <div class="challenge-card reveal delay-3" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="1" x2="12" y2="23"/>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Cash Flow Paralysis</h3>
          <p class="challenge-card__desc">When invoices age beyond 60 days, your operating cash flow suffers. You can't pay your own suppliers, you delay hiring, and growth projects are shelved. Recovering these funds isn't just about the past — it directly funds your future.</p>
        </div>

        <div class="challenge-card reveal delay-4" role="article">
          <div class="challenge-card__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3 class="challenge-card__title">Growth Stunted by Bad Debtors</h3>
          <p class="challenge-card__desc">Every business has that list of debtors they've written off. But written off doesn't mean unrecoverable. We pursue accounts that other agencies have passed on, and frequently recover funds that business owners had given up on entirely.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  HOW WE HELP                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad how-section" aria-labelledby="how-heading">
    <div class="container">
      <div class="how-inner">
        <div class="how-text reveal-left">
          <span class="eyebrow">Our Approach for Businesses</span>
          <h2 class="section-heading" id="how-heading">Scalable Commercial Debt Recovery</h2>
          <p>Whether you have one overdue invoice or a hundred, our recovery process is structured to handle your volume efficiently. We work with sole traders, SMEs, and large corporates using the same systematic approach — scaled to your needs.</p>
          <p>Our team is skilled in commercial debt negotiation, understanding the dynamics of B2B relationships and how to apply appropriate pressure without burning bridges that may still have value to you.</p>
          <p>For debtors who genuinely cannot pay in full, we negotiate structured payment plans that start recovering cash immediately while protecting the debtor relationship where that has commercial value.</p>
          <div class="how-text__types">
            <div class="type-tag">Sole Traders</div>
            <div class="type-tag">SMEs</div>
            <div class="type-tag">Retail Businesses</div>
            <div class="type-tag">Service Providers</div>
            <div class="type-tag">Contractors</div>
            <div class="type-tag">Landlords</div>
            <div class="type-tag">Corporates</div>
            <div class="type-tag">Franchises</div>
          </div>
        </div>
        <div class="how-steps reveal-right">
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">01</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Free Debt Portfolio Assessment</h3>
              <p>Submit your outstanding accounts for a no-charge assessment. We'll identify what's recoverable, the best strategy for each account, and the expected timeline — before you commit to anything.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">02</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Professional Demand &amp; Negotiation</h3>
              <p>We make contact with your debtors professionally, issuing formal demand notices and negotiating payment. Our presence alone often triggers payment from debtors who've been ignoring you.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">03</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Credit Bureau Listing &amp; Tracing</h3>
              <p>Non-responsive debtors face credit bureau listing, which has immediate consequences for their own creditworthiness. For debtors who've moved, our nationwide tracing services locate them.</p>
            </div>
          </div>
          <div class="how-step">
            <div class="how-step__num" aria-hidden="true">04</div>
            <div class="how-step__content">
              <h3 class="how-step__title">Legal Escalation Where Warranted</h3>
              <p>When other methods fail, we escalate to legal proceedings. We guide you through this process and work with legal professionals to secure judgments and enforcement where necessary.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  KEY BENEFITS                              -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad benefits-section" aria-labelledby="benefits-heading">
    <div class="container">
      <div class="benefits-intro reveal">
        <span class="eyebrow">Why Businesses Choose Us</span>
        <h2 class="section-heading" id="benefits-heading">A Recovery Partner That Works as Hard as You Do</h2>
      </div>
      <ul class="benefits-list" role="list">
        <li class="benefit-item reveal delay-1" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Commission-Only — Zero Financial Risk</strong>
            <p>You pay nothing upfront. Our commission is a percentage of recovered funds only. If we don't recover, you don't pay. Your downside is zero.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-2" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>At-Arm's-Length from Your Relationships</strong>
            <p>We take the pressure off your commercial relationships by acting independently. You stay the professional — we do the chasing.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-3" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Any Volume, Any Size</strong>
            <p>From a single overdue invoice of R5,000 to a portfolio of hundreds of accounts, our process scales to your needs without additional overhead on your side.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-4" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Nationwide Debtor Tracing</strong>
            <p>Debtors who have moved, changed numbers, or become deliberately unreachable are traced across all nine provinces using our tracing services.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-5" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>Monthly Cash Settlements</strong>
            <p>Recovered funds are paid directly to your business every month. You get your money without delay, along with a full account-by-account report.</p>
          </div>
        </li>
        <li class="benefit-item reveal delay-6" role="listitem">
          <div class="benefit-item__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <strong>POPIA &amp; Legally Compliant</strong>
            <p>Every step of our process complies with South African law. Registered company (Reg. 2025/184330/07), POPIA compliant, ethical in all dealings.</p>
          </div>
        </li>
      </ul>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CROSS-LINKS                               -->
  <!-- ══════════════════════════════════════════ -->
  <section class="section-pad crosslinks-section" aria-labelledby="crosslinks-heading">
    <div class="container">
      <div class="crosslinks-inner">
        <div class="reveal">
          <span class="eyebrow">Industries We Also Serve</span>
          <h2 class="section-heading" id="crosslinks-heading">Also Work in a Specific Sector?</h2>
          <p class="crosslinks-sub">We have dedicated expertise for schools and medical practices — with approaches tailored to the unique challenges of those industries.</p>
        </div>
        <div class="crosslinks-grid">
          <a href={`${base}industries/schools`} class="crosslink-card reveal delay-1" aria-label="Debt recovery for schools and education">
            <div class="crosslink-card__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V10l8-6 8 6v10"/><path d="M9 20v-5h6v5"/></svg>
            </div>
            <div>
              <strong>Schools &amp; Education</strong>
              <p>School fee recovery with a reputation-first approach.</p>
            </div>
            <svg class="crosslink-card__arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={`${base}industries/medical`} class="crosslink-card reveal delay-2" aria-label="Debt recovery for doctors and dentists">
            <div class="crosslink-card__icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div>
              <strong>Doctors &amp; Dentists</strong>
              <p>HPCSA-conscious recovery for medical and dental practices.</p>
            </div>
            <svg class="crosslink-card__arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════ -->
  <!--  CTA                                       -->
  <!-- ══════════════════════════════════════════ -->
  <section class="business-cta" aria-label="Free consultation call to action">
    <div class="container">
      <div class="business-cta__inner reveal">
        <span class="eyebrow eyebrow--red">Commission-Only — Zero Risk to Your Business</span>
        <h2 class="business-cta__heading">Start Recovering What's Owed to You Today</h2>
        <p class="business-cta__sub">
          Book a free, no-obligation consultation. Bring your age analysis or a list of outstanding accounts — we'll review everything and tell you exactly what we can recover and how. No commitment required.
        </p>
        <div class="business-cta__actions">
          <a href={`${base}contact`} class="btn btn-primary btn-lg">Book Free Consultation</a>
          <div class="business-cta__contact">
            <span>Or call directly:</span>
            <a href="tel:+27621165638" class="business-cta__tel">062 116 5638</a>
            <span aria-hidden="true">·</span>
            <a href="tel:+27814158260" class="business-cta__tel">081 415 8260</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────── */
  .business-hero {
    background-color: var(--color-navy);
    background-image:
      radial-gradient(ellipse at 80% 20%, rgba(192,57,43,0.2) 0%, transparent 55%),
      radial-gradient(ellipse at 5% 90%, rgba(255,255,255,0.03) 0%, transparent 50%);
    padding-top: calc(36px + 84px + 4rem);
    padding-bottom: 5rem;
    position: relative;
    overflow: hidden;
  }

  .business-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .eyebrow--orange {
    color: #F59E0B;
  }

  .eyebrow--red {
    color: var(--color-crimson);
  }

  .business-hero__heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 400;
    color: white;
    line-height: 1.15;
    margin-block: 0 1.25rem;
  }

  .business-hero__sub {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.8);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .business-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-badge {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: rgba(192,57,43,0.15);
    border: 1px solid rgba(192,57,43,0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #F87171;
    text-align: center;
    padding: 1.5rem;
  }

  .hero-badge__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .business-hero__wave {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    line-height: 0;
  }

  .business-hero__wave svg {
    width: 100%;
    height: 80px;
  }

  /* ── Stats Bar ─────────────────────────────── */
  .stats-bar {
    background: white;
    border-bottom: 1px solid var(--color-warm-100);
    padding-block: 2.5rem;
  }

  .stats-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    text-align: center;
    flex: 1;
  }

  .stat-item__num {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1;
  }

  .stat-item__label {
    font-size: 0.8125rem;
    color: var(--color-warm-600);
    line-height: 1.4;
    max-width: 200px;
    margin-inline: auto;
  }

  .stat-divider {
    width: 1px;
    height: 60px;
    background: var(--color-warm-100);
    flex-shrink: 0;
  }

  /* ── Challenge Section ─────────────────────── */
  .challenge-section {
    background-color: var(--color-ivory);
  }

  .challenge-intro {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 3.5rem;
  }

  .challenge-intro__sub {
    color: var(--color-warm-600);
    font-size: 1.0625rem;
    margin-top: 1rem;
    line-height: 1.7;
  }

  .challenge-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .challenge-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--color-crimson);
    transition: box-shadow 0.25s ease;
  }

  .challenge-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .challenge-card__icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background-color: rgba(192,57,43,0.08);
    color: var(--color-crimson);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .challenge-card__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
    font-weight: 400;
  }

  .challenge-card__desc {
    color: var(--color-warm-600);
    font-size: 0.9375rem;
    line-height: 1.7;
    margin: 0;
  }

  /* ── How We Help ───────────────────────────── */
  .how-section {
    background-color: var(--color-warm-50);
  }

  .how-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .how-text p {
    color: var(--color-warm-600);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .how-text .section-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }

  .how-text__types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .type-tag {
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
